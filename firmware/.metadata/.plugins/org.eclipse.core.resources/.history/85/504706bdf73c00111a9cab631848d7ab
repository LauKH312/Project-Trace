#include <main.h>
#include <hal_signal_path.h>
// Enable GPIOB clock
RCC->AHB4ENR |= RCC_AHB4ENR_GPIOBEN;

// PB13: output, push-pull, no pull, low speed
GPIOB->MODER   &= ~(0x3 << (13 * 2));
GPIOB->MODER   |=  (0x1 << (13 * 2));  // Output
GPIOB->OTYPER  &= ~(1 << 13);           // Push-pull
GPIOB->OSPEEDR &= ~(0x3 << (13 * 2));  // Low speed (fine for relay control)
GPIOB->PUPDR   &= ~(0x3 << (13 * 2));  // No pull

// Enable 20dB attenuation
GPIOB->BSRR = (1 << 13);       // Set high

// Disable 20dB attenuation
GPIOB->BSRR = (1 << (13+16));  // Set low
